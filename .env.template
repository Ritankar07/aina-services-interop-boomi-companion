# ═══════════════════════════════════════════════════════════════
#  Boomi Migration Workspace — Environment Variables
#  DO NOT COMMIT THIS FILE — it is in .gitignore
#
#  Variable names below match the verified official bc-integration
#  plugin's .env.example exactly, for compatibility if you ever
#  also install the official `gh skill install OfficialBoomi/boomi-integration`
#  skill alongside this workspace.
#  Source: github.com/OfficialBoomi/bc-integration/template/.env.example
# ═══════════════════════════════════════════════════════════════

# ─── Boomi Platform Credentials (REQUIRED) ──────────────────────
BOOMI_API_URL=https://api.boomi.com
BOOMI_USERNAME=your.email@company.com
BOOMI_API_TOKEN=generate_from_boomi_platform
BOOMI_ACCOUNT_ID=your_account_id
BOOMI_VERIFY_SSL=true

# ─── Target Folder (OPTIONAL — default folder for new components) ─
# This is used as the DEFAULT folder if /migrate's folder-path step
# is skipped. Normally you'll be prompted for a folder path each
# migration run (Step 6 of the workflow) and this will be ignored.
BOOMI_TARGET_FOLDER=folder_guid_here

# ─── Deployment (OPTIONAL) ───────────────────────────────────────
# Official spec has ONE BOOMI_ENVIRONMENT_ID. This workspace extends
# that with an explicit STG/PROD split as a safety convention for
# the LTM Interop Layer — always deploy to STG first.
BOOMI_ENVIRONMENT_ID=environment_guid
BOOMI_ENVIRONMENT_ID_STG=staging_environment_guid
BOOMI_ENVIRONMENT_ID_PROD=production_environment_guid
BOOMI_TEST_ATOM_ID=atom_guid

# ─── Optional: Shared Web Server (WSS endpoint testing) ──────────
# Valid SERVER_AUTH_TYPE values: basic | bearer | none
SERVER_AUTH_TYPE=basic
SERVER_BASE_URL=https://your-atom.integrate.boomi.com
SERVER_USERNAME=
SERVER_TOKEN=
SERVER_BEARER_TOKEN=
SERVER_VERIFY_SSL=false

# ─── Activity Logging (OPTIONAL, opt-in — NOT on by default) ────
# Writes script operations to .activity-log/activity.jsonl locally.
# Uncomment to enable:
# BOOMI_COMPANION_LOG_ACTIVITY=1

# ─── Confluence Cloud (for /document push) ───────────────────────
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USER=your-email@company.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE_KEY=INTEROP
CONFLUENCE_PARENT_PAGE_ID=your-parent-page-id

# ─── GitHub (Optional — for sync_boomi_references.py) ───────────────────────
# Personal Access Token for checking official repo updates.
# Without this, the sync script is limited to 60 GitHub API calls/hour.
# Generate at: github.com/settings/tokens → Generate new token → repo:read scope
# GITHUB_TOKEN=ghp_your_token_here
